generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id     Int     @id @default(autoincrement())
  nome   String
  email  String  @unique
  login  String  @unique
  senha  String
  admin  Boolean @default(false)

  createdAt DateTime @default(now())
}
