generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id     Int     @id @default(autoincrement())
  nome   String
  email  String  @unique
  login  String  @unique
  senha  String
  admin  Boolean @default(false)
  createdAt DateTime @default(now())

  reviews   Reviews[]
  loans     Loan[]
}

model Reviews {
  id         Int     @id @default(autoincrement())
  nota       String
  comentario String
  createdAt  DateTime @default(now())
  imageUrl   String?

  userId     Int
  user       User     @relation(fields: [userId], references: [id])

  bookId     Int
  book       Book     @relation(fields: [bookId], references: [id])
}

model Author {
  id     Int    @id @default(autoincrement())
  nome   String

  books  Book[]
}

model Category {
  id    Int    @id @default(autoincrement())
  nome  String

  books Book[]
}

model Book {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  isbn        String?  @unique
  imageUrl    String?
  quantity    Int      @default(1)
  createdAt   DateTime @default(now())

  authorId    Int
  author      Author   @relation(fields: [authorId], references: [id])

  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id])

  reviews     Reviews[]
  loans       Loan[]
}

model Loan {
  id          Int      @id @default(autoincrement())
  loanDate    DateTime @default(now())
  returnDate  DateTime?
  returned    Boolean  @default(false)

  userId      Int
  user        User     @relation(fields: [userId], references: [id])

  bookId      Int
  book        Book     @relation(fields: [bookId], references: [id])
}