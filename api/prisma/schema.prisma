generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id     Int     @id @default(autoincrement())
  nome   String
  email  String  @unique
  login  String  @unique
  senha  String
  admin  Boolean @default(false)
  createdAt DateTime @default(now())

  reviews   Reviews[]
}

model Reviews {
  id         Int     @id @default(autoincrement())
  nota       String
  comentario String
  createdAt  DateTime @default(now())
  imageUrl   String?

  userId     Int
  user       User     @relation(fields: [userId], references: [id])
}